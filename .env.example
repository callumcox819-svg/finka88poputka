BOT_TOKEN=
ADMIN_IDS=
VALIDEMAIL_API_KEY=
VALIDEMAIL_API_KEY_2=
VALIDEMAIL_API_KEY_3=
VALIDEMAIL_API_KEY_4=
VALIDEMAIL_API_KEY_5=
# или одной строкой: VALIDEMAIL_API_KEYS=key1,key2,key3,key4,key5
# параллельных воркеров подбора (по умолчанию ≈ 2× число ключей, макс. = ключи × VALIDEMAIL_CONCURRENCY)
# VALIDEMAIL_PARALLEL_WORKERS=10
# множитель по умолчанию, если WORKERS не задан (2 = два объявления на ключ)
# VALIDEMAIL_PARALLEL_FACTOR=2
DEEPL_API_KEY=

# PostgreSQL (Railway: добавьте плагин Postgres — DATABASE_URL подставится сам)
DATABASE_URL=

SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SEND_DELAY_SEC=2
INCOMING_POLL_SEC=60
